{
  "name": "@angel-vlqz/reportflow-core",
  "version": "0.1.2",
  "description": "Declarative TypeScript PDF layout engine for enterprise reporting (pagination, tables, charts, theming).",
  "keywords": [
    "pdf",
    "reporting",
    "b2b",
    "typescript",
    "node",
    "layout-engine",
    "business-reports"
  ],
  "license": "MIT",
  "author": "Luis Ángel Velázquez Palomino",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src test --ext .ts,.tsx",
    "test": "vitest run"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "zod": "^3.24.2"
  }
}
